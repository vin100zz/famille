# Normalisation des fins de ligne
# Tous les fichiers texte sont stockés en LF dans le dépôt.
# Git convertit automatiquement au format local lors du checkout.

* text=auto

# Fichiers toujours en LF (pas de conversion CRLF sur Windows)
*.json        text eol=lf
*.js          text eol=lf
*.css         text eol=lf
*.html        text eol=lf
*.php         text eol=lf
*.py          text eol=lf
*.md          text eol=lf
*.txt         text eol=lf
*.csv         text eol=lf
*.ged         text eol=lf

# Fichiers binaires (pas de conversion)
*.woff2       binary
*.png         binary
*.jpg         binary
*.jpeg        binary

